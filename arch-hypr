#!/usr/bin/env bash
set -euo pipefail

# ---------------------------------------------------------------------------
# Post-install setup: Arch Linux + Hyprland (Wayland + Pipewire)
# ThinkPad X1 Carbon Gen 9
# ---------------------------------------------------------------------------

# Install an AUR package into /tmp (cleaned up on reboot)
function aurinst {
    local pkg="$1"
    echo "Installing AUR package: $pkg"
    # Skip if already installed
    if pacman -Qi "$pkg" &>/dev/null; then
        echo "$pkg is already installed, skipping"
        return
    fi
    mkdir -p /tmp/aur
    rm -rf "/tmp/aur/$pkg"
    cd /tmp/aur && git clone "https://aur.archlinux.org/${pkg}.git" && cd "$pkg" && yes | makepkg -sic --needed
    rm -rf "/tmp/aur/$pkg"
}

# ---------------------------------------------------------------------------
# Mirrors & system update
# ---------------------------------------------------------------------------
sudo pacman -S --noconfirm --needed reflector rsync git
sudo reflector --country gb --fastest 10 --save /etc/pacman.d/mirrorlist
sudo pacman -Suy --noconfirm

# ---------------------------------------------------------------------------
# Timezone & NTP
# ---------------------------------------------------------------------------
sudo ln -sf /usr/share/zoneinfo/Europe/London /etc/localtime
sudo mkdir -p /etc/systemd/timesyncd.conf.d
sudo bash -c 'cat <<EOF > /etc/systemd/timesyncd.conf.d/local.conf
[Time]
NTP=10.76.42.100 10.76.40.100 10.76.44.100
FallbackNTP=time.google.com
EOF'
sudo timedatectl set-ntp true

