# ---------------------------------------------------------------------------
sudo flatpak install -y flathub \
    spotify \
    slack \
    com.valvesoftware.Steam \
    im.riot.Riot \
    org.telegram.desktop \
    org.telegram.desktop.webview \
    com.bitwarden.desktop \
    app/com.usebruno.Bruno/x86_64/stable \
    app/io.beekeeperstudio.Studio/x86_64/stable

# ---------------------------------------------------------------------------
# UFW firewall
# ---------------------------------------------------------------------------
sudo ufw default deny incoming
sudo ufw default allow outgoing
sudo ufw allow ssh
sudo ufw enable

# ---------------------------------------------------------------------------
# Enable services
# ---------------------------------------------------------------------------
sudo systemctl enable --now ModemManager
sudo systemctl enable --now avahi-daemon
sudo systemctl enable --now acpid
sudo systemctl enable --now cups.socket
sudo systemctl enable --now cups
sudo systemctl enable --now bluetooth
sudo systemctl enable --now power-profiles-daemon
sudo systemctl enable --now fwupd
sudo systemctl enable --now libvirtd.service
sudo systemctl enable --now docker.socket
sudo systemctl enable ly@tty1

# ---------------------------------------------------------------------------
# libvirt virtual bridge network (NAT via virbr10 on 192.168.100.0/24)
# ---------------------------------------------------------------------------
if ! sudo virsh net-info vmbr &>/dev/null; then
    sudo virsh net-define /dev/stdin <<'EOF'
<network>
  <name>vmbr</name>
  <forward mode='nat'/>
  <bridge name='virbr10' stp='on' delay='0'/>
  <ip address='192.168.100.1' netmask='255.255.255.0'>
    <dhcp>
      <range start='192.168.100.2' end='192.168.100.254'/>
    </dhcp>
  </ip>
</network>
EOF
fi
sudo virsh net-autostart vmbr
sudo virsh net-start vmbr 2>/dev/null || true

echo ""
echo "Done! Reboot to start Hyprland via ly."

