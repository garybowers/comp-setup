# ---------------------------------------------------------------------------
# Printer polkit rule (allows wheel group to manage printers without password)
# ---------------------------------------------------------------------------
sudo bash -c 'cat <<EOF > /etc/polkit-1/rules.d/49-allow-passwordless-printer-admin.rules
polkit.addRule(function(action, subject) {
    if (action.id == "org.opensuse.cupspkhelper.mechanism.all-edit" &&
        subject.isInGroup("wheel")) {
        return polkit.Result.YES;
    }
});
EOF'

# ---------------------------------------------------------------------------
# mDNS / NSSwitch fix for network printing discovery
# ---------------------------------------------------------------------------
