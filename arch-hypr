# GPU detection — install appropriate Vulkan/VA-API drivers
# ---------------------------------------------------------------------------
if lspci | grep -i "VGA\|3D" | grep -iq intel; then
    echo "Intel GPU detected"
    sudo pacman -S --noconfirm --needed vulkan-intel intel-media-driver
fi
if lspci | grep -i "VGA\|3D" | grep -iq amd; then
    echo "AMD GPU detected"
    sudo pacman -S --noconfirm --needed vulkan-radeon libva-mesa-driver
fi

